# 環境變量配置模板
# 使用方法：複製此文件為 .env，然後填入實際的 API Key

# Google Gemini API Key
GOOGLE_API_KEY = your_google_api_key_here

# Serper API Key（用於 Google Images 搜尋）
SERPER_API_KEY = your_serper_api_key_here

# Flask 運行模式（本地開發設為 True，生產環境設為 False）
FLASK_DEBUG = True

# Flask 密鑰（生產環境推薦設置）
FLASK_SECRET_KEY = your_secret_key_here_change_in_production

# 應用端口（默認 5000）
PORT = 5000
